{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WranglerLabs/ranch-hand/contracts/deployment-plan.schema.json",
  "title": "Ranch Hand deployment plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "release", "target", "configuration"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "manifestUrl", "manifestSha256", "artifactSha256", "artifactSize"],
      "properties": {
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$" },
        "manifestUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
        "manifestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "artifactSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "artifactSize": { "type": "integer", "minimum": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["azure-container-apps", "cloudflare", "local-compose", "remote-linux-compose"] }
      }
    },
    "configuration": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "target": { "properties": { "kind": { "const": "azure-container-apps" } } } } },
      "then": { "properties": { "configuration": { "$ref": "#/$defs/azureContainerApps" } } }
    },
    {
      "if": { "properties": { "target": { "properties": { "kind": { "const": "cloudflare" } } } } },
      "then": { "properties": { "configuration": { "$ref": "#/$defs/cloudflare" } } }
    },
    {
      "if": { "properties": { "target": { "properties": { "kind": { "const": "local-compose" } } } } },
      "then": { "properties": { "configuration": { "$ref": "#/$defs/localCompose" } } }
    },
    {
      "if": { "properties": { "target": { "properties": { "kind": { "const": "remote-linux-compose" } } } } },
      "then": { "properties": { "configuration": { "$ref": "#/$defs/remoteLinuxCompose" } } }
    }
  ],
  "$defs": {
    "azureContainerApps": {
      "type": "object", "additionalProperties": false,
      "required": ["subscriptionId", "resourceGroup", "location", "environmentName", "appName"],
      "properties": {
        "subscriptionId": { "$ref": "#/$defs/value" }, "resourceGroup": { "$ref": "#/$defs/value" },
        "location": { "$ref": "#/$defs/value" }, "environmentName": { "$ref": "#/$defs/value" },
        "appName": { "$ref": "#/$defs/value" }, "customDomain": { "$ref": "#/$defs/value" }
      }
    },
    "cloudflare": {
      "type": "object", "additionalProperties": false,
      "required": ["accountId", "workerName", "databaseName"],
      "properties": {
        "accountId": { "$ref": "#/$defs/value" }, "workerName": { "$ref": "#/$defs/value" },
        "databaseName": { "$ref": "#/$defs/value" }, "customDomain": { "$ref": "#/$defs/value" }
      }
    },
    "localCompose": {
      "type": "object", "additionalProperties": false,
      "required": ["projectName", "dataVolume", "listenAddress"],
      "properties": {
        "projectName": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,62}$" },
        "dataVolume": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,62}$" },
        "listenAddress": { "type": "string", "pattern": "^127\\.0\\.0\\.1:[0-9]{4,5}$" }
      }
    },
    "remoteLinuxCompose": {
      "type": "object", "additionalProperties": false,
      "required": ["host", "port", "user", "installDirectory", "projectName", "hostKeySha256"],
      "properties": {
        "host": { "$ref": "#/$defs/value" }, "port": { "$ref": "#/$defs/value" },
        "user": { "$ref": "#/$defs/value" }, "installDirectory": { "$ref": "#/$defs/value" },
        "projectName": { "$ref": "#/$defs/value" }, "hostKeySha256": { "$ref": "#/$defs/value" }
      }
    },
    "value": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\r\\n\\u0000]+$" }
  }
}
